{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "^startup$",
        "hooks": [
          {
            "type": "command",
            "command": "node ./platform/adapters/codex/hooks/scripts/session-start.mjs",
            "timeout": 10,
            "statusMessage": "Loading quorum context"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ./platform/adapters/codex/hooks/scripts/session-stop.mjs",
            "timeout": 10,
            "statusMessage": "Running quorum cleanup"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ./platform/adapters/codex/hooks/scripts/prompt-submit.mjs",
            "timeout": 5,
            "statusMessage": "Checking quorum status"
          }
        ]
      }
    ],
    "AfterAgent": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ./platform/adapters/codex/hooks/scripts/after-agent.mjs",
            "timeout": 30,
            "statusMessage": "Running quorum post-turn checks"
          }
        ]
      }
    ],
    "AfterToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ./platform/adapters/codex/hooks/scripts/after-tool-use.mjs",
            "timeout": 30,
            "statusMessage": "Evaluating quorum audit trigger"
          }
        ]
      }
    ]
  }
}
